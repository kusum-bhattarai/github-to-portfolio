# ── Local dev (docker-compose) ────────────────────────────────────────────────

# GitHub OAuth App — register at https://github.com/settings/developers
# Dev callback URL: http://localhost:8080/login/oauth2/code/github
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=portfolio_dev

# 32-byte AES key for encrypting GitHub access tokens at rest (base64-encoded)
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

# LLM API key (OpenAI or compatible)
LLM_API_KEY=your_llm_api_key_here

# ── Production (GCP Cloud Run) — set these in Cloud Run env vars ──────────────

# Spring profile
# SPRING_PROFILES_ACTIVE=prod

# Neon Postgres — connection string from neon.tech dashboard
# DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# DB_USERNAME=your_neon_username
# DB_PASSWORD=your_neon_password

# Upstash Redis — from upstash.com dashboard
# REDIS_HOST=your-db.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your_upstash_redis_password

# Upstash Kafka — from upstash.com dashboard
# KAFKA_BOOTSTRAP_SERVERS=your-cluster.upstash.io:9092
# KAFKA_USERNAME=your_upstash_kafka_username
# KAFKA_PASSWORD=your_upstash_kafka_password

# URLs (set to your actual deployed URLs)
# FRONTEND_URL=https://your-app.vercel.app
# BACKEND_URL=https://your-service-xxx.run.app
