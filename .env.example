# GitHub OAuth App credentials
# Register at: https://github.com/settings/developers
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:8080/login/oauth2/code/github
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=portfolio_dev

# 32-byte AES key for encrypting GitHub access tokens at rest (base64-encoded)
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

# LLM API key (OpenAI or compatible)
LLM_API_KEY=your_llm_api_key_here
